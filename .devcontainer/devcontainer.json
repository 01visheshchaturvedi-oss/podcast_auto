JSON
{
  "name": "Aakashvani Podcast Environment",
  
  // Installs system dependencies (like FFmpeg for pydub) during container creation
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ffmpeg python3.13-venv",

  // Installs Python packages directly into the auto-created .venv upon startup
  "postStartCommand": "if [ -d \".venv\" ]; then .venv/bin/python -m pip install --upgrade pip && .venv/bin/python -m pip install pydub; fi",

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  }
}
