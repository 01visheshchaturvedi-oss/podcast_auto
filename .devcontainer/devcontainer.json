{
    "name": "Podcast AI Generator",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/ffmpeg:1": {}
    },
    "postCreateCommand": "pip install --no-cache-dir edge-tts pydub gtts",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python3"
            }
        }
    }
}
